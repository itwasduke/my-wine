rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cellar/{document=**} {
      // Public read — the inventory is a personal display, no sensitive data.
      allow read: if true;

      // All writes require the signed-in owner UID.
      allow create, update, delete: if request.auth != null
                                    && request.auth.uid == "yV9R26u5U6YFqZ6p0uX0pY9R26u5";
    }
  }
}
