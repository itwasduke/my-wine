rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cellar/{document=**} {
      // Public read — the inventory is a personal display, no sensitive data.
      allow read: if true;

      // Create and update allowed — PIN enforcement happens in the app.
      // Deletes are blocked; bottles are marked consumed, never removed.
      allow create, update: if true;
      allow delete: if false;
    }
  }
}
