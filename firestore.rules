rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cellar/{document=**} {
      // Public read — the inventory is a personal display, no sensitive data.
      allow read: if true;

      // Writes (create + update) require the signed-in owner UID.
      // Replace [YOUR_UID_HERE] with your Firebase Auth UID after first sign-in:
      //   Firebase Console → Authentication → Users → copy the User UID column.
      allow create, update: if request.auth != null
                            && request.auth.uid == "[YOUR_UID_HERE]";

      // Deletes are permanently blocked.
      allow delete: if false;
    }
  }
}
